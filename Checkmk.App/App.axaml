<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Checkmk.App.Converters"
             x:Class="Checkmk.App.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <!-- Kroste-Palette (Referenz: Klemmbrett-Scaffold) -->
    <SolidColorBrush x:Key="KrosteBackgroundBrush" Color="#1A1D21" />
    <SolidColorBrush x:Key="KrosteTitleBarBrush" Color="#14161A" />
    <SolidColorBrush x:Key="KrosteSurfaceBrush" Color="#22262B" />
    <SolidColorBrush x:Key="KrosteAccentBrush" Color="#123E6B" />
    <SolidColorBrush x:Key="KrosteGoldBrush" Color="#E0B14C" />
    <conv:StateToBrushConverter x:Key="StateToBrush" />
    <conv:OsToBrushConverter x:Key="OsToBrush" />
    <conv:OsToIconConverter x:Key="OsToIcon" />
    <conv:BoolToHealthBrushConverter x:Key="BoolToHealthBrush" />
    <conv:AgeToBrushConverter x:Key="AgeToBrush" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

    <!-- Titelleisten-Fensterbuttons (Referenz: Klemmbrett-Scaffold) -->
    <Style Selector="Button.chrome">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="40" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.chrome:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#2A2E33" />
    </Style>
    <Style Selector="Button.chrome.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#C42B1C" />
    </Style>
  </Application.Styles>

</Application>
