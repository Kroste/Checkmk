<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        x:Class="Checkmk.App.Views.PluginUpdatesDialog"
        Width="560" Height="440"
        Title="Plugin-Updates"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,Auto,*,Auto,Auto">

      <controls:TitleBar Grid.Row="0" Title="Plugin-Updates" />

      <TextBlock Grid.Row="1" x:Name="StatusText" Margin="20,16,20,8"
                 Foreground="#AAAAAA" TextWrapping="Wrap" />

      <ScrollViewer Grid.Row="2" Margin="20,4,20,8">
        <ItemsControl x:Name="UpdatesList">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:CompileBindings="False">
              <Border Background="#252526" CornerRadius="6" Padding="12,8" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding PluginName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding PluginId}" Foreground="#707070" FontSize="11" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding CurrentVersion}"
                             VerticalAlignment="Center" Foreground="#888888" Margin="0,0,8,0" />
                  <TextBlock Grid.Column="2" Text="→" VerticalAlignment="Center"
                             Foreground="#707070" Margin="4,0" />
                  <TextBlock Grid.Column="3" Text="{Binding LatestVersion}"
                             VerticalAlignment="Center" FontWeight="SemiBold"
                             Foreground="#66BB6A" Margin="8,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <StackPanel Grid.Row="3" x:Name="ProgressPanel" IsVisible="False"
                  Margin="20,4,20,8" Spacing="4">
        <ProgressBar x:Name="DownloadBar" Minimum="0" Maximum="1" Height="8" />
        <TextBlock x:Name="ProgressText" FontSize="12" Foreground="#AAAAAA" />
      </StackPanel>

      <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="20,0,20,16" Spacing="8">
        <Button x:Name="RecheckButton" Content="Erneut prüfen" Click="OnRecheckClick" />
        <Button x:Name="CloseButton" Content="Schließen" Click="OnCloseClick" />
        <Button x:Name="InstallButton" Content="Alle installieren" Click="OnInstallClick"
                Background="#123E6B" IsDefault="True" IsEnabled="False" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
