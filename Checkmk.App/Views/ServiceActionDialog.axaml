<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        xmlns:vm="using:Checkmk.App.ViewModels"
        x:Class="Checkmk.App.Views.ServiceActionDialog"
        x:DataType="vm:ServiceActionDialogViewModel"
        Width="460" Height="300"
        Title="Aktion"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,*,Auto">

      <Border Grid.Row="0" Background="#252526" PointerPressed="OnTitleBarPressed">
        <TextBlock Text="{Binding Header}" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="12,0" />
      </Border>

      <StackPanel Grid.Row="1" Margin="16" Spacing="10">
        <StackPanel Spacing="2">
          <TextBlock Text="Ziel" Foreground="#AAAAAA" FontSize="12" />
          <TextBlock Text="{Binding Target}" FontWeight="SemiBold" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="2" IsVisible="{Binding IsDowntime}">
          <TextBlock Text="Dauer" Foreground="#AAAAAA" FontSize="12" />
          <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                    HorizontalAlignment="Stretch" />
        </StackPanel>

        <StackPanel Spacing="2">
          <TextBlock Text="Kommentar (Pflicht)" Foreground="#AAAAAA" FontSize="12" />
          <TextBox Text="{Binding Comment}" AcceptsReturn="True" Height="70"
                   TextWrapping="Wrap" PlaceholderText="Grund / Ticket-Nr. …" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="16" Spacing="8">
        <Button Content="OK" Command="{Binding OkCommand}" Background="#0E639C" />
        <Button Content="Abbrechen" Command="{Binding CancelCommand}" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
