<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        x:Class="Checkmk.App.Views.HostSettingsDialog"
        Width="480" Height="420"
        Title="Host-Einstellungen"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,*,Auto">

      <controls:TitleBar Grid.Row="0" x:Name="AppTitleBar" Title="Host-Einstellungen" />

      <StackPanel Grid.Row="1" Margin="20" Spacing="12">

        <TextBlock Text="Domain (zentral, wird für Ping/RDP/SSH als FQDN verwendet)"
                   Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" />
        <TextBox Name="DomainBox"
                 PlaceholderText="lhp.intern (Default) oder dmz.lhp.intern" />

        <TextBlock Text="SSH-Anmeldung (lokal — nur du siehst diese Werte)"
                   Foreground="#AAAAAA" FontSize="12" Margin="0,8,0,0" />
        <StackPanel Spacing="4">
          <TextBlock Text="Anmeldename" Foreground="#888888" FontSize="11" />
          <TextBox Name="SshUserBox" PlaceholderText="root, admin, …" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Passwort (verschlüsselt gespeichert, beim SSH-Start in Zwischenablage)"
                     Foreground="#888888" FontSize="11" TextWrapping="Wrap" />
          <TextBox Name="SshPasswordBox" PasswordChar="•" />
        </StackPanel>

      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="16" Spacing="8">
        <Button Content="Speichern" Click="OnSaveClick" Background="#123E6B" IsDefault="True" />
        <Button Content="Abbrechen" Click="OnCancelClick" IsCancel="True" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
