<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Checkmk.App.ViewModels"
             xmlns:models="using:Checkmk.Core.Models"
             x:Class="Checkmk.App.Views.StatusView"
             x:DataType="vm:StatusViewModel">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Toolbar -->
    <Grid Grid.Row="0" RowDefinitions="Auto,Auto" Margin="4,4,4,8">
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBox Name="FilterTextBox" Grid.Column="0" Text="{Binding FilterText}"
                 PlaceholderText="Freitext-Filter (Host/Service/Ausgabe, case-insensitive Contains)… — Ctrl+F fokussiert, Esc leert" />
        <Button Grid.Column="1" Content="Acknowledge…" Click="OnAcknowledgeClick"
                IsEnabled="{Binding SelectedService, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <Button Grid.Column="2" Content="Downtime…" Click="OnDowntimeClick"
                IsEnabled="{Binding SelectedService, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <CheckBox Grid.Column="3" Content="Nur Probleme" IsChecked="{Binding OnlyProblems}"
                  VerticalAlignment="Center" />
        <CheckBox Grid.Column="4" Content="Nur offen" IsChecked="{Binding OnlyOpen}"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Blendet Ack'd und in Wartung befindliche Services aus — die tatsächliche Arbeitsliste." />
        <CheckBox Grid.Column="5" Content="Auto" IsChecked="{Binding AutoRefresh}"
                  VerticalAlignment="Center" />
        <NumericUpDown Grid.Column="6" Value="{Binding RefreshSeconds}" Minimum="5" Maximum="600"
                       Increment="5" Width="110" FormatString="0's'" />
        <Button Grid.Column="7" Content="Aktualisieren" Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsBusy}" />
      </Grid>
      <Grid Grid.Row="1" ColumnDefinitions="Auto,240,Auto,*,Auto,Auto" ColumnSpacing="8" Margin="0,6,0,0">
        <TextBlock Grid.Column="0" Text="Host-Filter:" VerticalAlignment="Center" Foreground="#AAAAAA" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding Filters.Filters}"
                  SelectedItem="{Binding Filters.Active}"
                  PlaceholderText="(Alle Hosts)"
                  DisplayMemberBinding="{Binding Name}" />
        <ToggleButton Grid.Column="2" Content="Baumansicht" IsChecked="{Binding TreeView}"
                      VerticalAlignment="Center" />
        <Button Grid.Column="4" Content="CSV-Export…" Click="OnExportCsvClick" />
        <Button Grid.Column="5" Content="Filter verwalten…" Click="OnManageFiltersClick" />
      </Grid>
    </Grid>

    <!-- Zusammenfassung -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="4,0,4,8">
      <TextBlock Text="{Binding HostsUp, StringFormat='Hosts UP: {0}'}" Foreground="#66BB6A" />
      <TextBlock Text="{Binding HostsDown, StringFormat='DOWN: {0}'}" Foreground="#EF5350" />
      <Rectangle Width="1" Fill="#444" />
      <TextBlock Text="{Binding ServicesOk, StringFormat='OK: {0}'}" Foreground="#66BB6A" />
      <TextBlock Text="{Binding ServicesWarn, StringFormat='WARN: {0}'}" Foreground="#FFCA28" />
      <TextBlock Text="{Binding ServicesCrit, StringFormat='CRIT: {0}'}" Foreground="#EF5350" />
    </StackPanel>

    <!-- Service-Tabelle -->
    <DataGrid Name="ServiceGrid" Grid.Row="2" ItemsSource="{Binding Services}"
              IsVisible="{Binding !TreeView}"
              SelectedItem="{Binding SelectedService}"
              IsReadOnly="True" GridLinesVisibility="Horizontal"
              CanUserResizeColumns="True" CanUserSortColumns="True"
              SelectionMode="Extended"
              DoubleTapped="OnServiceDoubleTapped">
      <DataGrid.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Host-Details…" Click="OnOpenHostDetailsClick" />
          <Separator />
          <MenuItem Header="Acknowledge…" Click="OnAcknowledgeClick" />
          <MenuItem Header="Downtime…" Click="OnDowntimeClick" />
          <MenuItem Header="Kommentar…" Click="OnCommentClick" />
          <Separator />
          <MenuItem Header="Im Checkmk-Web öffnen" Click="OnOpenInWebClick" />
          <Separator />
          <MenuItem Header="Remote-Shell öffnen (auto: RDP/SSH)" Click="OnRemoteShellClick" />
          <MenuItem Header="RDP öffnen" Click="OnRdpClick" />
          <MenuItem Header="SSH öffnen" Click="OnSshClick" />
          <MenuItem Header="Ping (Fenster)" Click="OnPingClick" />
          <Separator />
          <MenuItem Header="Host-Einstellungen (Domain/SSH)…" Click="OnHostSettingsClick" />
          <Separator />
          <MenuItem Header="Client aktualisieren…" Click="OnUpdateClientClick" />
        </ContextMenu>
      </DataGrid.ContextMenu>
      <DataGrid.Columns>
        <DataGridTemplateColumn Header="" Width="34">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="models:ServiceStatus">
              <Border Width="14" Height="14" CornerRadius="7"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Background="{Binding ServiceState, Converter={StaticResource StateToBrush}}" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <DataGridTextColumn Header="Host" Binding="{Binding HostName}" Width="160" />
        <DataGridTextColumn Header="Alias" Binding="{Binding HostAlias}" Width="180" />
        <DataGridTextColumn Header="Service" Binding="{Binding Description}" Width="200" />
        <DataGridTextColumn Header="Status" Binding="{Binding ServiceState}" Width="90" />
        <DataGridTextColumn Header="Ausgabe" Binding="{Binding PluginOutput}" Width="*" />
        <DataGridCheckBoxColumn Header="Ack" Binding="{Binding IsAcknowledged}" Width="50" />
        <DataGridCheckBoxColumn Header="DT" Binding="{Binding InDowntime}" Width="50" />
        <DataGridTemplateColumn Header="Age" Width="90" SortMemberPath="LastStateChange">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="models:ServiceStatus">
              <TextBlock Text="{Binding Age}"
                         Foreground="{Binding LastStateChange, Converter={StaticResource AgeToBrush}}"
                         VerticalAlignment="Center" Margin="6,0" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Baum-Ansicht: Hosts -> Services -->
    <TreeView Grid.Row="2" IsVisible="{Binding TreeView}" ItemsSource="{Binding HostTree}"
              SelectedItem="{Binding SelectedTreeItem}"
              DoubleTapped="OnServiceDoubleTapped">
      <TreeView.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Host-Details…" Click="OnOpenHostDetailsClick" />
          <Separator />
          <MenuItem Header="Acknowledge…" Click="OnAcknowledgeClick" />
          <MenuItem Header="Downtime…" Click="OnDowntimeClick" />
          <MenuItem Header="Kommentar…" Click="OnCommentClick" />
          <Separator />
          <MenuItem Header="Im Checkmk-Web öffnen" Click="OnOpenInWebClick" />
          <Separator />
          <MenuItem Header="Remote-Shell öffnen (auto: RDP/SSH)" Click="OnRemoteShellClick" />
          <MenuItem Header="RDP öffnen" Click="OnRdpClick" />
          <MenuItem Header="SSH öffnen" Click="OnSshClick" />
          <MenuItem Header="Ping (Fenster)" Click="OnPingClick" />
          <Separator />
          <MenuItem Header="Host-Einstellungen (Domain/SSH)…" Click="OnHostSettingsClick" />
          <Separator />
          <MenuItem Header="Client aktualisieren…" Click="OnUpdateClientClick" />
        </ContextMenu>
      </TreeView.ContextMenu>
      <TreeView.DataTemplates>
        <TreeDataTemplate DataType="vm:HostNodeViewModel" ItemsSource="{Binding Services}">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <ContentControl Content="{Binding Os, Converter={StaticResource OsToIcon}}"
                            Width="26" Height="26" VerticalAlignment="Center" />
            <Border Width="12" Height="12" CornerRadius="6" VerticalAlignment="Center"
                    Background="{Binding WorstState, Converter={StaticResource StateToBrush}}" />
            <TextBlock Text="{Binding HostName}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ProblemBadge}" Foreground="#EF5350" VerticalAlignment="Center"
                       IsVisible="{Binding HasProblems}" />
          </StackPanel>
        </TreeDataTemplate>

        <DataTemplate DataType="models:ServiceStatus">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center"
                    Background="{Binding ServiceState, Converter={StaticResource StateToBrush}}" />
            <TextBlock Text="{Binding Description}" VerticalAlignment="Center" MinWidth="200" />
            <TextBlock Text="{Binding PluginOutput}" Foreground="#AAAAAA" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </DataTemplate>
      </TreeView.DataTemplates>
    </TreeView>
  </Grid>
</UserControl>
