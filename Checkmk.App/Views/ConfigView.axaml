<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Checkmk.App.ViewModels"
             xmlns:models="using:Checkmk.Core.Models"
             x:Class="Checkmk.App.Views.ConfigView"
             x:DataType="vm:ConfigViewModel">

  <Grid RowDefinitions="Auto,Auto,Auto,*">

    <!-- Host anlegen (per Bootstrap.ShowHostCreation ein-/ausblendbar; Default aus) -->
    <Border Grid.Row="0" Background="#252526" CornerRadius="6" Padding="12" Margin="4"
            IsVisible="{Binding IsHostCreationVisible}">
      <StackPanel Spacing="8">
        <TextBlock Text="Host anlegen" FontWeight="SemiBold" />
        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
          <TextBox Grid.Column="0" Text="{Binding NewHostName}" PlaceholderText="Hostname *" />
          <TextBox Grid.Column="1" Text="{Binding NewHostFolder}" PlaceholderText="Ordner (/)" />
          <TextBox Grid.Column="2" Text="{Binding NewHostIp}" PlaceholderText="IP-Adresse" />
          <TextBox Grid.Column="3" Text="{Binding NewHostAlias}" PlaceholderText="Alias" />
        </Grid>
        <Button Content="Anlegen" Command="{Binding CreateHostCommand}"
                IsEnabled="{Binding !IsBusy}" HorizontalAlignment="Left" />
      </StackPanel>
    </Border>

    <!-- Aktions-Toolbar (immer sichtbar) -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="8,4">
      <Button Content="Services entdecken" Command="{Binding DiscoverServicesCommand}"
              ToolTip.Tip="Startet Service-Discovery (fix_all) auf dem markierten Host und aktiviert die Änderungen.">
        <Button.IsEnabled>
          <MultiBinding Converter="{x:Static BoolConverters.And}">
            <Binding Path="!IsBusy" />
            <Binding Path="SelectedHost" Converter="{x:Static ObjectConverters.IsNotNull}" />
          </MultiBinding>
        </Button.IsEnabled>
      </Button>
      <Button Content="Änderungen aktivieren" Command="{Binding ActivateChangesCommand}"
              IsEnabled="{Binding !IsBusy}" Background="#123E6B" />
      <Button Content="Liste neu laden" Command="{Binding RefreshHostsCommand}"
              IsEnabled="{Binding !IsBusy}" />
    </StackPanel>

    <Grid Grid.Row="2" ColumnDefinitions="Auto,240,Auto,*,Auto" ColumnSpacing="8" Margin="8,4">
      <TextBlock Grid.Column="0" Text="Host-Filter:" VerticalAlignment="Center" Foreground="#AAAAAA" />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding Filters.Filters}"
                SelectedItem="{Binding Filters.Active}"
                PlaceholderText="(Alle Hosts)"
                DisplayMemberBinding="{Binding Name}" />
      <Button Grid.Column="2" Content="Auswahl als Favorit…" Click="OnSaveSelectionAsFavoriteClick"
              ToolTip.Tip="Speichert die markierten Hosts als benannten Favoriten (Ctrl+Klick für Mehrfachauswahl)." />
      <TextBlock Grid.Column="3" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                 Foreground="#AAAAAA" Margin="12,0,0,0" />
      <Button Grid.Column="4" Content="Filter verwalten…" Click="OnManageFiltersClick" />
    </Grid>

    <!-- Host-Liste -->
    <DataGrid Name="HostGrid" Grid.Row="3" ItemsSource="{Binding Hosts}"
              SelectedItem="{Binding SelectedHost}" IsReadOnly="True"
              GridLinesVisibility="Horizontal" Margin="4"
              CanUserResizeColumns="True" CanUserSortColumns="True"
              SelectionMode="Extended"
              DoubleTapped="OnHostDoubleTapped">
      <DataGrid.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Host-Details…" Click="OnOpenHostDetailsClick" />
          <Separator />
          <MenuItem Header="Services entdecken (fix_all + aktivieren)"
                    Command="{Binding DiscoverServicesCommand}" />
          <Separator />
          <MenuItem Header="Auswahl als Favorit…" Click="OnSaveSelectionAsFavoriteClick" />
          <MenuItem Header="Auswahl zu Favorit hinzufügen…" Click="OnAddToFavoriteClick" />
          <Separator />
          <MenuItem Header="Remote-Shell öffnen (auto: RDP/SSH)" Click="OnRemoteShellClick" />
          <MenuItem Header="RDP öffnen" Click="OnRdpClick" />
          <MenuItem Header="SSH öffnen" Click="OnSshClick" />
          <MenuItem Header="Ping (Fenster)" Click="OnPingClick" />
          <MenuItem Header="Im Checkmk-Web öffnen" Click="OnOpenHostInWebClick" />
          <Separator />
          <MenuItem Header="Host-Einstellungen (Domain/SSH)…" Click="OnHostSettingsClick" />
        </ContextMenu>
      </DataGrid.ContextMenu>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Host" Binding="{Binding Id}" Width="220" />
        <DataGridTextColumn Header="Ordner" Binding="{Binding Extensions.Folder}" Width="200" />
        <DataGridTextColumn Header="IP-Adresse"
                            Binding="{Binding Extensions.Attributes.IpAddress}" Width="160" />
        <DataGridTextColumn Header="Alias"
                            Binding="{Binding Extensions.Attributes.Alias}" Width="*" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
