<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        xmlns:vm="using:Checkmk.App.ViewModels"
        x:Class="Checkmk.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Width="560" Height="640"
        Title="Verbindung"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,*,Auto">

      <controls:TitleBar Grid.Row="0" Title="Checkmk-Verbindung" />

      <ScrollViewer Grid.Row="1">
      <StackPanel Margin="16" Spacing="10">
        <StackPanel Spacing="3">
          <TextBlock Text="Host" />
          <TextBox Text="{Binding Host}" PlaceholderText="monitoring.lhp.intern" />
        </StackPanel>
        <StackPanel Spacing="3">
          <TextBlock Text="Site" />
          <TextBox Text="{Binding Site}" PlaceholderText="prod" />
        </StackPanel>
        <StackPanel Spacing="3">
          <TextBlock Text="Bekannte Sites am selben Server (kommasepariert, für Umschalter)" />
          <TextBox Text="{Binding KnownSitesCsv}"
                   PlaceholderText="LHP-Prod, Schul_IT" />
          <TextBlock Text="Leer lassen, wenn nur eine Site. Sonst erscheint oben rechts ein Site-Umschalter."
                     Foreground="#707070" FontSize="11" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="3">
          <TextBlock Text="Anmeldemethode" />
          <StackPanel Orientation="Horizontal" Spacing="20">
            <RadioButton GroupName="AuthMode" Content="Windows/LDAP (empfohlen)"
                         IsChecked="{Binding IsUserBasic, Mode=TwoWay}" />
            <RadioButton GroupName="AuthMode" Content="Automation-User (Legacy)"
                         IsChecked="{Binding IsAutomationBearer, Mode=TwoWay}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding UsernameLabel}" />
          <TextBox Text="{Binding Username}" />
          <TextBlock Text="{Binding UsernameHint}" Foreground="#707070"
                     FontSize="11" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding SecretLabel}" />
          <TextBox Text="{Binding Secret}" PasswordChar="•" />
          <TextBlock Text="{Binding SecretHint}" Foreground="#707070"
                     FontSize="11" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="20">
          <CheckBox Content="HTTPS" IsChecked="{Binding UseHttps}" />
          <CheckBox Content="Zertifikatsfehler ignorieren (Lab)"
                    IsChecked="{Binding IgnoreCertificateErrors}" />
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAAAA" TextWrapping="Wrap" />
        <TextBlock Text="{Binding StorageLocationLabel}" Foreground="#707070"
                   FontSize="11" TextWrapping="Wrap" />
      </StackPanel>
      </ScrollViewer>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="16" Spacing="8">
        <Button Content="Testen" Command="{Binding TestCommand}" IsEnabled="{Binding !IsBusy}" />
        <Button Content="Speichern" Command="{Binding SaveCommand}" Background="#123E6B" />
        <Button Content="Abbrechen" Command="{Binding CancelCommand}" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
