<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        x:Class="Checkmk.App.Views.AgentUpdateWindow"
        Width="680" Height="480"
        Title="Client-Aktualisierung"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,Auto,*,Auto">
      <controls:TitleBar Grid.Row="0" x:Name="AppTitleBar" Title="Client-Aktualisierung" />

      <TextBlock Grid.Row="1" x:Name="StatusText" Margin="16,12,16,6" Foreground="#AAAAAA" />

      <TextBox Grid.Row="2" x:Name="OutputBox" Margin="16,0" IsReadOnly="True"
               AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas,monospace"
               VerticalContentAlignment="Top" />

      <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="16" Spacing="8">
        <Button x:Name="CloseButton" Content="Schliessen" Click="OnCloseClick" IsEnabled="False" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
