<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        xmlns:vm="using:Checkmk.App.ViewModels"
        xmlns:views="using:Checkmk.App.Views"
        xmlns:chrome="using:Avalonia.Controls.Chrome"
        x:Class="Checkmk.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1000" Height="680"
        MinWidth="720" MinHeight="480"
        Title="Checkmk Cockpit"
        WindowStartupLocation="CenterScreen">

  <Border BorderBrush="#3A3A3A" BorderThickness="1"
          Background="{DynamicResource KrosteBackgroundBrush}">
    <Grid RowDefinitions="40,*,26">

      <controls:TitleBar Grid.Row="0" Title="Checkmk Cockpit">
        <controls:TitleBar.Extras>
          <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
            <Border Background="{DynamicResource KrosteAccentBrush}" CornerRadius="3" Padding="6,1"
                    VerticalAlignment="Center" Margin="0,0,12,0"
                    ToolTip.Tip="Ziel-Backend: Checkmk 2.5, REST-API v1">
              <TextBlock Text="2.5 · v1" FontSize="11" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                        Margin="0,0,12,0" IsVisible="{Binding IsSiteSwitcherVisible}">
              <TextBlock Text="Site:" Foreground="#AAAAAA" VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding KnownSites}"
                        SelectedItem="{Binding ActiveSite, Mode=TwoWay}"
                        MinWidth="140" VerticalAlignment="Center"
                        ToolTip.Tip="Zwischen bekannten Sites am gleichen Server umschalten (Host/User/Secret bleiben)." />
            </StackPanel>
            <Button Content="Einstellungen" Command="{Binding OpenSettingsCommand}"
                    Background="Transparent" Padding="12,0" />
            <Button Content="Über" Command="{Binding OpenAboutCommand}"
                    Background="Transparent" Padding="12,0" />
          </StackPanel>
        </controls:TitleBar.Extras>
      </controls:TitleBar>

      <!-- Inhalt -->
      <TabControl Name="MainTabs" Grid.Row="1" Margin="8">
        <TabItem Header="Status">
          <views:StatusView DataContext="{Binding Status}" />
        </TabItem>
        <TabItem Header="Hosts">
          <views:ConfigView DataContext="{Binding Config}" />
        </TabItem>
        <TabItem Header="Dashboard">
          <views:DashboardView DataContext="{Binding Dashboard}" />
        </TabItem>
      </TabControl>

      <!-- Statusleiste -->
      <Border Grid.Row="2" Background="#123E6B">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="10,0">
          <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5"
                  VerticalAlignment="Center" Margin="0,0,8,0"
                  Background="{Binding Status.IsBackendHealthy, Converter={StaticResource BoolToHealthBrush}}"
                  ToolTip.Tip="Backend-Verbindung: grün = letzter Refresh erfolgreich, rot = Fehler." />
          <TextBlock Grid.Column="1" Text="{Binding Status.StatusMessage}"
                     VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Column="2" Text="{Binding Status.FilterInfo}"
                     VerticalAlignment="Center" FontSize="12" Margin="10,0,0,0"
                     Foreground="#B5D0EA" />
          <Button Grid.Column="3" Content="{Binding UpdateBadge}"
                  Command="{Binding OpenUpdateCommand}"
                  IsVisible="{Binding HasUpdate}"
                  Background="#F9A825" Foreground="#000000"
                  Padding="10,2" Margin="8,0,10,0" FontSize="12" FontWeight="SemiBold"
                  ToolTip.Tip="Klicken für Release-Notes und Download-Link." />
          <TextBlock Grid.Column="4" Text="{Binding ConnectionInfo}"
                     VerticalAlignment="Center" FontSize="12" Margin="10,0,0,0" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</controls:ChromeWindow>
