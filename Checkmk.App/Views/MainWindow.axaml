<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        xmlns:vm="using:Checkmk.App.ViewModels"
        xmlns:views="using:Checkmk.App.Views"
        x:Class="Checkmk.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1000" Height="680"
        MinWidth="720" MinHeight="480"
        Title="Checkmk Cockpit"
        WindowStartupLocation="CenterScreen">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,*,26">

      <!-- Titelleiste -->
      <Border Grid.Row="0" Background="#252526" PointerPressed="OnTitleBarPressed">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0" Spacing="8"
                      VerticalAlignment="Center">
            <TextBlock Text="Checkmk Cockpit" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Border Background="#123E6B" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
              <TextBlock Text="2.5 · v1" FontSize="11" />
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
            <Button Content="Einstellungen" Command="{Binding OpenSettingsCommand}"
                    Background="Transparent" Padding="12,0" />
            <Button Content="Über" Command="{Binding OpenAboutCommand}"
                    Background="Transparent" Padding="12,0" />
            <Button Content="—" Click="OnMinimizeClick" Background="Transparent" Width="42" />
            <Button Content="▢" Click="OnMaximizeClick" Background="Transparent" Width="42" />
            <Button Content="✕" Click="OnCloseClick" Background="Transparent" Width="42" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Inhalt -->
      <TabControl Grid.Row="1" Margin="8">
        <TabItem Header="Status">
          <views:StatusView DataContext="{Binding Status}" />
        </TabItem>
        <TabItem Header="Hosts">
          <views:ConfigView DataContext="{Binding Config}" />
        </TabItem>
      </TabControl>

      <!-- Statusleiste -->
      <Border Grid.Row="2" Background="#123E6B">
        <Grid ColumnDefinitions="*,Auto,Auto" Margin="10,0">
          <TextBlock Grid.Column="0" Text="{Binding Status.StatusMessage}"
                     VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" />
          <Button Grid.Column="1" Content="{Binding UpdateBadge}"
                  Command="{Binding OpenUpdateCommand}"
                  IsVisible="{Binding HasUpdate}"
                  Background="#F9A825" Foreground="#000000"
                  Padding="10,2" Margin="8,0,10,0" FontSize="12" FontWeight="SemiBold"
                  ToolTip.Tip="Klicken für Release-Notes und Download-Link." />
          <TextBlock Grid.Column="2" Text="{Binding ConnectionInfo}"
                     VerticalAlignment="Center" FontSize="12" Margin="10,0,0,0" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</controls:ChromeWindow>
