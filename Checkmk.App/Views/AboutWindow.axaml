<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        x:Class="Checkmk.App.Views.AboutWindow"
        Width="400" Height="380"
        Title="Über"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1"
          Background="{DynamicResource KrosteBackgroundBrush}">
    <Grid RowDefinitions="40,*">
      <controls:TitleBar Grid.Row="0" Title="Über Checkmk Cockpit" />

      <StackPanel Grid.Row="1" Margin="20" Spacing="10" VerticalAlignment="Center">
        <TextBlock Text="Checkmk Cockpit" FontSize="20" FontWeight="Bold" />
        <TextBlock x:Name="VersionText" Foreground="#AAAAAA" />
        <TextBlock Text="Status &amp; Konfiguration für Checkmk 2.5 (REST-API v1)"
                   TextWrapping="Wrap" Foreground="#CCCCCC" />
        <Border Background="#252526" CornerRadius="4" Padding="10" Margin="0,6,0,0">
          <StackPanel Spacing="2">
            <TextBlock Text="Fachbereich" Foreground="#888888" FontSize="11" />
            <TextBlock Text="5424 IT-Basis-Dienste" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
          <Button Content="Nach Updates suchen" x:Name="CheckUpdatesButton"
                  Click="OnCheckUpdatesClick" />
          <Button Content="Plugin-Updates…" Click="OnPluginUpdatesClick" />
          <Button Content="GitHub" Click="OnGithubClick" />
          <Button Content="Schließen" Click="OnDismissClick" />
        </StackPanel>
        <TextBlock x:Name="UpdateStatusText" Foreground="#AAAAAA" FontSize="12"
                   TextWrapping="Wrap" IsVisible="False" Margin="0,4,0,0" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
