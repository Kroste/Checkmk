<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        x:Class="Checkmk.App.Views.CredentialDialog"
        Width="400" Height="240"
        Title="Admin-Anmeldung"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,*,Auto">
      <controls:TitleBar Grid.Row="0" Title="Admin-Anmeldung für Remote-Update" />

      <StackPanel Grid.Row="1" Margin="16" Spacing="10">
        <TextBlock x:Name="TargetText" Foreground="#AAAAAA" TextWrapping="Wrap" />
        <StackPanel Spacing="3">
          <TextBlock Text="Benutzer (z. B. LHP\\Admin)" />
          <TextBox x:Name="UserBox" PlaceholderText="DOMAENE\\Benutzer" />
        </StackPanel>
        <StackPanel Spacing="3">
          <TextBlock Text="Passwort" />
          <TextBox x:Name="PassBox" PasswordChar="•" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="16" Spacing="8">
        <Button Content="Weiter" Click="OnOkClick" Background="#123E6B" />
        <Button Content="Abbrechen" Click="OnCancelClick" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
