<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        x:Class="Checkmk.App.Views.NameInputDialog"
        Width="440" Height="200"
        Title="Name"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,*,Auto">

      <controls:TitleBar Grid.Row="0" x:Name="AppTitleBar" Title="Name" />

      <StackPanel Grid.Row="1" Margin="16" Spacing="10">
        <TextBlock Name="PromptText" Foreground="#AAAAAA" TextWrapping="Wrap" />
        <TextBox Name="ValueBox" />
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="16" Spacing="8">
        <Button Content="OK" Click="OnOkClick" Background="#123E6B" IsDefault="True" />
        <Button Content="Abbrechen" Click="OnCancelClick" IsCancel="True" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
