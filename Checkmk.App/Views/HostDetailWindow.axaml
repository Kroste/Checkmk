<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        xmlns:vm="using:Checkmk.App.ViewModels"
        xmlns:models="using:Checkmk.Core.Models"
        x:Class="Checkmk.App.Views.HostDetailWindow"
        x:DataType="vm:HostDetailViewModel"
        Width="1000" Height="640"
        MinWidth="720" MinHeight="480"
        Title="Host-Details"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,Auto,Auto,*,Auto">

      <!-- Titelleiste -->
      <Border Grid.Row="0" Background="#252526" PointerPressed="OnTitleBarPressed">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0" Spacing="8"
                      VerticalAlignment="Center">
            <TextBlock Text="Host-Details:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding HostName}" VerticalAlignment="Center" Foreground="#0E639C"
                       FontWeight="SemiBold" />
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal">
            <Button Content="—" Click="OnMinimizeClick" Background="Transparent" Width="42" />
            <Button Content="▢" Click="OnMaximizeClick" Background="Transparent" Width="42" />
            <Button Content="✕" Click="OnCloseClick" Background="Transparent" Width="42" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Host-Kopf: State + Attribute -->
      <Border Grid.Row="1" Background="#252526" CornerRadius="6" Margin="8" Padding="14">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Border Width="18" Height="18" CornerRadius="9"
                    Background="{Binding HostStatus.HostState, Converter={StaticResource StateToBrush}, FallbackValue=#616161}"
                    VerticalAlignment="Center" />
            <TextBlock Text="{Binding HostStatus.HostState, FallbackValue=?}" FontSize="18"
                       FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>

          <Grid Grid.Column="1" Margin="20,0,0,0"
                ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto"
                ColumnSpacing="10" RowSpacing="2">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ordner" Foreground="#888" FontSize="11" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding HostConfig.Extensions.Folder, FallbackValue=—}" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="IP" Foreground="#888" FontSize="11" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding HostConfig.Extensions.Attributes.IpAddress, FallbackValue=—}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Alias" Foreground="#888" FontSize="11" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HostConfig.Extensions.Attributes.Alias, FallbackValue=—}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Ack" Foreground="#888" FontSize="11" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding HostStatus.IsAcknowledged, FallbackValue=—}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Ausgabe" Foreground="#888" FontSize="11" />
            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                       Text="{Binding HostStatus.PluginOutput, FallbackValue=—}"
                       TextWrapping="Wrap" />
          </Grid>

          <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="4" VerticalAlignment="Center">
            <Button Content="Host-Ack…" Click="OnHostAckClick" />
            <Button Content="Host-Downtime…" Click="OnHostDowntimeClick" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Service-Aggregate + Aktionen -->
      <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="14"
            Margin="14,0,14,8">
        <TextBlock Grid.Column="0" Text="{Binding ServicesOk, StringFormat='OK: {0}'}"
                   Foreground="#66BB6A" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding ServicesWarn, StringFormat='WARN: {0}'}"
                   Foreground="#FFCA28" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding ServicesCrit, StringFormat='CRIT: {0}'}"
                   Foreground="#EF5350" VerticalAlignment="Center" />
        <TextBlock Grid.Column="3" Text="{Binding ServicesUnknown, StringFormat='UNK: {0}'}"
                   Foreground="#AAAAAA" VerticalAlignment="Center" />
        <Button Grid.Column="5" Content="Ack…" Click="OnServiceAckClick"
                IsEnabled="{Binding SelectedService, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <Button Grid.Column="6" Content="Downtime…" Click="OnServiceDowntimeClick"
                IsEnabled="{Binding SelectedService, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <Button Grid.Column="7" Content="Aktualisieren" Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsBusy}" />
      </Grid>

      <!-- Service-Tabelle -->
      <DataGrid Grid.Row="3" ItemsSource="{Binding Services}"
                SelectedItem="{Binding SelectedService}"
                IsReadOnly="True" GridLinesVisibility="Horizontal" Margin="8,0,8,0"
                CanUserResizeColumns="True" CanUserSortColumns="True">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Acknowledge…" Click="OnServiceAckClick" />
            <MenuItem Header="Downtime…" Click="OnServiceDowntimeClick" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="34">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:ServiceStatus">
                <Border Width="14" Height="14" CornerRadius="7"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{Binding ServiceState, Converter={StaticResource StateToBrush}}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Service" Binding="{Binding Description}" Width="260" />
          <DataGridTextColumn Header="Status" Binding="{Binding ServiceState}" Width="90" />
          <DataGridTextColumn Header="Ausgabe" Binding="{Binding PluginOutput}" Width="*" />
          <DataGridCheckBoxColumn Header="Ack" Binding="{Binding IsAcknowledged}" Width="50" />
          <DataGridCheckBoxColumn Header="DT" Binding="{Binding InDowntime}" Width="50" />
          <DataGridTextColumn Header="Letzter Check"
                              Binding="{Binding LastCheck, StringFormat='{}{0:HH:mm:ss}'}" Width="110" />
        </DataGrid.Columns>
      </DataGrid>

      <!-- Statusleiste -->
      <Border Grid.Row="4" Background="#007ACC">
        <TextBlock Text="{Binding StatusMessage}" Margin="10,4" FontSize="12"
                   TextTrimming="CharacterEllipsis" />
      </Border>
    </Grid>
  </Border>
</controls:ChromeWindow>
