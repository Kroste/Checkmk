<controls:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Checkmk.App.Controls"
        x:Class="Checkmk.App.Views.UpdateDialog"
        Width="520" Height="520"
        Title="Update verfügbar"
        WindowStartupLocation="CenterOwner">

  <Border BorderBrush="#3A3A3A" BorderThickness="1" Background="#1E1E1E">
    <Grid RowDefinitions="40,Auto,*,Auto,Auto">

      <controls:TitleBar Grid.Row="0" Title="Update verfügbar" />

      <StackPanel Grid.Row="1" Margin="20,16,20,8" Spacing="4">
        <TextBlock Text="Neue Version verfügbar" FontSize="18" FontWeight="Bold" />
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Name="VersionText" Foreground="#123E6B" FontWeight="SemiBold" />
          <TextBlock Name="CurrentVersionText" Foreground="#888888" />
        </StackPanel>
      </StackPanel>

      <Border Grid.Row="2" Background="#252526" CornerRadius="6" Margin="20,4,20,12" Padding="12">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Text="Release-Notes" Foreground="#888888" FontSize="11"
                     Margin="0,0,0,6" />
          <ScrollViewer Grid.Row="1">
            <TextBlock Name="NotesText" TextWrapping="Wrap" FontFamily="Consolas,Courier New,monospace" />
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Fortschritts-Anzeige beim Installieren (sonst ausgeblendet) -->
      <StackPanel Grid.Row="3" Name="ProgressPanel" IsVisible="False"
                  Margin="20,0,20,10" Spacing="4">
        <ProgressBar Name="DownloadBar" Minimum="0" Maximum="1" Height="8" />
        <TextBlock Name="ProgressText" FontSize="12" Foreground="#AAAAAA" />
      </StackPanel>

      <StackPanel Grid.Row="4" Name="ButtonRow" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="20,0,20,16" Spacing="8">
        <Button Name="SkipButton" Content="Diese Version überspringen" Click="OnSkipClick" />
        <Button Name="LaterButton" Content="Später" Click="OnLaterClick" />
        <Button Name="ReleaseButton" Content="Release-Seite öffnen" Click="OnOpenReleaseClick" />
        <Button Name="InstallButton" Content="Jetzt installieren" Click="OnInstallClick"
                Background="#123E6B" IsDefault="True" />
      </StackPanel>
    </Grid>
  </Border>
</controls:ChromeWindow>
