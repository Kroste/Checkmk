{
  // Windows-only-Projekt: bewusst KEIN publish-linux-x64 / kein AppImage
  // (siehe CLAUDE.md, Grundlagen). Release erzeugt nur die win-x64-ZIP.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/Checkmk.slnx",
        "-c", "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "build-release",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/Checkmk.slnx",
        "-c", "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/Checkmk.slnx",
        "-c", "Release"
      ],
      "problemMatcher": "$msCompile",
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "watch",
      "detail": "Startet die App mit Hot-Reload (dotnet watch).",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch", "run",
        "--project", "${workspaceFolder}/Checkmk.App/Checkmk.App.csproj"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "command": "dotnet",
      "type": "process",
      "args": ["clean", "${workspaceFolder}/Checkmk.slnx"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish-win-x64",
      "detail": "Self-contained Single-File-EXE nach publish/win-x64.",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish", "${workspaceFolder}/Checkmk.App/Checkmk.App.csproj",
        "-c", "Release", "-r", "win-x64", "--self-contained",
        "-p:PublishSingleFile=true",
        "-p:IncludeNativeLibrariesForSelfExtract=true",
        "-o", "${workspaceFolder}/publish/win-x64"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "release (tag + push)",
      "detail": "Annotierten Tag vX.Y.Z setzen und pushen -> loest die Release-Action (Windows-ZIP) aus.",
      "type": "shell",
      "problemMatcher": [],
      "linux": { "command": "bash '${workspaceFolder}/scripts/release.sh'" },
      "osx": { "command": "bash '${workspaceFolder}/scripts/release.sh'" },
      "windows": { "command": "pwsh -NoProfile -File '${workspaceFolder}/scripts/release.ps1'" },
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "clean-hard",
      "detail": "Loescht rekursiv alle bin/- und obj/-Ordner.",
      "type": "shell",
      "problemMatcher": [],
      "linux": { "command": "find '${workspaceFolder}' -type d \\( -name bin -o -name obj \\) -prune -exec rm -rf '{}' +" },
      "osx": { "command": "find '${workspaceFolder}' -type d \\( -name bin -o -name obj \\) -prune -exec rm -rf '{}' +" },
      "windows": {
        "command": "Get-ChildItem -Path '${workspaceFolder}' -Recurse -Directory -Include bin,obj | Remove-Item -Recurse -Force",
        "options": { "shell": { "executable": "powershell.exe", "args": ["-NoProfile", "-Command"] } }
      }
    }
  ]
}
