<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Windows-TFM, damit App-Klassen (HostFilterCollection etc.) referenzierbar sind.
         Ueberschreibt den net10.0-Default aus Directory.Build.props. -->
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <OutputType>Exe</OutputType>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="FluentAssertions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Checkmk.Core/Checkmk.Core.csproj" />
    <ProjectReference Include="../Checkmk.App/Checkmk.App.csproj" />
  </ItemGroup>

</Project>
